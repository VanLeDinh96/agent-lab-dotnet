<div class="flex flex-col items-center justify-center min-h-full p-6 bg-gray-50 relative">
    <div class="scanline"></div>

    <div class="text-center max-w-sm relative z-10">
        <h1 class="neon-text text-5xl md:text-6xl mb-2 neon-text-glow">
            ⟨ SOC OPS ⟩
        </h1>
        <p class="text-2xl text-gray-500 mb-2" style="letter-spacing: 3px;">SOCIAL BINGO</p>
        <p class="text-xs text-gray-600 mb-8" style="letter-spacing: 2px;">[NEURAL LINK ACTIVATED]</p>

        <div class="neon-card neon-border-cyan rounded-lg p-6 mb-8">
            <h2 class="neon-text text-lg mb-4">⟨ MISSION PROTOCOL ⟩</h2>
            <ul class="text-left text-gray-600 text-sm space-y-2 font-mono">
                <li>→ Scan for matching targets</li>
                <li>→ Establish connection with verified matches</li>
                <li>→ Complete a BINGO line to achieve mission success</li>
                <li>→ Evade detection until victory</li>
            </ul>
        </div>

        <button
            @onclick="OnStart"
            class="neon-button w-full py-4 px-8 rounded text-lg font-mono">
            [ INITIALIZE NEURAL LINK ]
        </button>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnStart { get; set; }
}
