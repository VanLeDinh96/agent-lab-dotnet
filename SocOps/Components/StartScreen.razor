<div class="flex flex-col items-center justify-center min-h-full p-6 md:p-8 bg-cozy-pattern">
    <div class="text-center max-w-sm">
        <h1 class="text-4xl md:text-5xl font-serif text-serif-heading text-rust mb-2">Soc Ops</h1>
        <p class="text-lg text-warm-gray mb-8">Social Bingo</p>

        <div class="bg-warm-white rounded-lg p-6 shadow-lg border border-warm-taupe mb-8">
            <h2 class="font-serif text-serif-heading text-rust text-lg mb-4">How to play</h2>
            <ul class="text-left text-warm-gray text-sm space-y-2">
                <li>• Find people who match the questions</li>
                <li>• Tap a square when you find a match</li>
                <li>• Get 5 in a row to win!</li>
            </ul>
        </div>

        <button
            @onclick="OnStart"
            class="w-full bg-rust text-white font-semibold py-4 px-8 rounded-lg text-lg active:bg-burnt-orange transition-colors shadow-lg hover:shadow-xl">
            Start Game
        </button>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnStart { get; set; }
}
