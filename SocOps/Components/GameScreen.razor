@using SocOps.Models

<div class="flex flex-col min-h-full bg-gray-50 relative">
    <div class="scanline"></div>

    <!-- Header -->
    <header class="flex items-center justify-between p-3 neon-border-cyan border-b bg-gray-100 relative z-10">
        <button
            @onclick="OnReset"
            class="neon-button px-4 py-1.5 text-xs font-mono rounded">
            [ ← ABORT ]
        </button>
        <h1 class="neon-text text-lg">⟨ SOC OPS ⟩</h1>
        <div class="w-16"></div>
    </header>

    <!-- Instructions -->
    <p class="text-center text-gray-600 text-xs py-2 px-4 font-mono relative z-10" style="letter-spacing: 1px;">
        → TARGET ACQUISITION MODE ACTIVE →
    </p>

    <!-- Bingo indicator -->
    @if (HasBingo)
    {
        <div class="neon-card neon-border-cyan text-center py-3 font-bold text-sm relative z-20" style="background: linear-gradient(90deg, rgba(0, 255, 255, 0.2), rgba(255, 0, 255, 0.2));">
            <span class="neon-text" style="color: #ffff00; text-shadow: 0 0 15px #ffff00;">
                ⚡ MISSION CRITICAL - BINGO ACHIEVED! ⚡
            </span>
        </div>
    }

    <!-- Board -->
    <div class="flex-1 flex items-center justify-center p-3 relative z-10">
        <BingoBoard
            Board="@Board"
            WinningSquareIds="@WinningSquareIds"
            OnSquareClick="@OnSquareClick" />
    </div>
</div>

@code {
    [Parameter]
    public List<BingoSquareData> Board { get; set; } = new();

    [Parameter]
    public HashSet<int> WinningSquareIds { get; set; } = new();

    [Parameter]
    public bool HasBingo { get; set; }

    [Parameter]
    public EventCallback<int> OnSquareClick { get; set; }

    [Parameter]
    public EventCallback OnReset { get; set; }
}
