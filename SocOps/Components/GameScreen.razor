@using SocOps.Models

<div class="flex flex-col min-h-full bg-cozy-pattern">
    <!-- Header -->
    <header class="flex items-center justify-between p-4 bg-gradient-to-r from-rust to-burnt-orange text-white shadow-lg border-b border-warm-taupe">
        <button
            @onclick="OnReset"
            class="text-white text-sm px-3 py-1.5 rounded active:bg-rust transition-colors opacity-90 hover:opacity-100">
            ← Back
        </button>
        <h1 class="font-serif text-serif-heading text-lg">Soc Ops</h1>
        <div class="w-16"></div>
    </header>

    <!-- Instructions -->
    <p class="text-center text-warm-gray text-sm py-3 px-4 bg-warm-white bg-opacity-50">
        Tap a square when you find someone who matches it.
    </p>

    <!-- Bingo indicator -->
    @if (HasBingo)
    {
        <div class="bg-deep-gold text-white text-center py-3 font-semibold text-sm shadow-md">
            🎉 BINGO! You got a line!
        </div>
    }

    <!-- Board -->
    <div class="flex-1 flex items-center justify-center p-6">
        <BingoBoard
            Board="@Board"
            WinningSquareIds="@WinningSquareIds"
            OnSquareClick="@OnSquareClick" />
    </div>
</div>

@code {
    [Parameter]
    public List<BingoSquareData> Board { get; set; } = new();

    [Parameter]
    public HashSet<int> WinningSquareIds { get; set; } = new();

    [Parameter]
    public bool HasBingo { get; set; }

    [Parameter]
    public EventCallback<int> OnSquareClick { get; set; }

    [Parameter]
    public EventCallback OnReset { get; set; }
}
