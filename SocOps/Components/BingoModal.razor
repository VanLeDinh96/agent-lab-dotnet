<div class="fixed inset-0 bg-black/50 flex items-center justify-center p-4 z-50">
    <div class="bg-warm-white rounded-xl p-8 max-w-xs w-full text-center shadow-xl animate-[bounce_0.5s_ease-out] border-2 border-deep-gold">
        <div class="text-5xl mb-4">🎉</div>
        <h2 class="text-3xl font-serif text-serif-heading text-rust mb-2">BINGO!</h2>
        <p class="text-warm-gray mb-6">You completed a line!</p>

        <button
            @onclick="OnDismiss"
            class="w-full bg-rust text-white font-semibold py-3 px-6 rounded-lg active:bg-burnt-orange transition-colors shadow-lg">
            Keep Playing
        </button>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnDismiss { get; set; }
}
