<div class="fixed inset-0 bg-black/80 flex items-center justify-center p-4 z-50" style="background: linear-gradient(45deg, rgba(0, 0, 0, 0.8), rgba(255, 0, 255, 0.2), rgba(0, 0, 0, 0.8));">
    <div class="neon-card neon-border-cyan rounded-xl p-8 max-w-xs w-full text-center shadow-xl animate-[bounce_0.5s_ease-out]" style="box-shadow: 0 0 50px #00ffff, 0 0 100px #ff00ff, inset 0 0 50px rgba(0, 255, 255, 0.3);">
        <div class="text-5xl mb-4" style="animation: glow-pulse 1s infinite;">
            ⚡ ⬤ ⚡
        </div>
        <h2 class="neon-text text-4xl mb-2" style="color: #ffff00; text-shadow: 0 0 20px #ffff00, 0 0 40px #ff00ff;">
            BINGO!
        </h2>
        <p class="text-gray-600 mb-6 font-mono text-sm" style="letter-spacing: 2px;">
            [ MISSION OBJECTIVE COMPLETE ]
        </p>
        <p class="text-gray-500 mb-6 font-mono text-xs">
            Neural connection established. Continuing operation...
        </p>

        <button
            @onclick="OnDismiss"
            class="neon-button w-full py-3 px-6 rounded-lg font-mono text-sm" style="border-color: #ffff00; color: #ffff00; text-shadow: 0 0 10px #ffff00;">
            [ CONTINUE TRANSMISSION ]
        </button>
    </div>
</div>

@code {
    [Parameter]
    public EventCallback OnDismiss { get; set; }
}
