@using SocOps.Models

<button
    @onclick="OnClick"
    disabled="@Square.IsFreeSpace"
    class="@GetCssClasses()"
    aria-pressed="@Square.IsMarked"
    aria-label="@(Square.IsFreeSpace ? "Free space" : Square.Text)">
    <span class="wrap-break-word hyphens-auto">@Square.Text</span>
    @if (Square.IsMarked && !Square.IsFreeSpace)
    {
        <span class="absolute top-0.5 right-0.5 text-sage text-xs">✓</span>
    }
</button>

@code {
    [Parameter]
    public BingoSquareData Square { get; set; } = null!;

    [Parameter]
    public bool IsWinning { get; set; }

    [Parameter]
    public EventCallback OnClick { get; set; }

    private string GetCssClasses()
    {
        var baseClasses = "relative flex items-center justify-center p-1 text-center border border-warm-taupe rounded transition-all duration-150 select-none min-h-[60px] text-xs leading-tight shadow-sm";

        var stateClasses = Square.IsMarked
            ? IsWinning
                ? "bg-deep-gold text-white border-deep-gold"
                : "bg-sage text-white border-sage"
            : "bg-warm-white text-deep-charcoal active:bg-warm-taupe hover:shadow-md";

        var freeSpaceClasses = Square.IsFreeSpace ? "font-bold text-sm" : "";

        return $"{baseClasses} {stateClasses} {freeSpaceClasses}";
    }
}
